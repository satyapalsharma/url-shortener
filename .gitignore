# Git ignore file for URL Shortener project

# Python specific ignores
# Byte-code files
*.pyc
*.pyo
__pycache__/

# Virtual environment
# It's good practice to ignore your virtual environment directory.
# Common names are 'venv' or 'env'.
venv/
env/

# IDE specific files
# Ignore files generated by common IDEs like VS Code or PyCharm.
.vscode/
.idea/

# Database files
# The SQLite database file is generated and should not be committed to version control.
# The 'instance/' directory often contains runtime-generated files like the database.
instance/

# Log files
# Ignore any application log files.
*.log

# Operating System specific files
# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor backup/temporary files
# Vim swap files, Emacs backup files, etc.
*~
*.swp
.#*

# Testing related files (if applicable)
# If you use pytest, this directory stores cache information.
.pytest_cache/

# Type checking cache (if applicable, e.g., MyPy)
.mypy_cache/